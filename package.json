{
  "name": "wealth-checker",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun run --filter='@wealth/web' dev",
    "dev:api": "bun run --filter='@wealth/api' dev",
    "build": "bun run --filter='@wealth/web' build",
    "build:api": "bun run --filter='@wealth/api' build",
    "lint": "bun run --filter='@wealth/web' lint",
    "test": "bun run --filter='@wealth/api' test && bun run --filter='@wealth/web' test",
    "typecheck": "bun run --filter='*' typecheck",
    "db:generate": "bun run --filter='@wealth/db' generate",
    "db:migrate": "bun run --filter='@wealth/db' migrate",
    "db:studio": "bun run --filter='@wealth/db' studio",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "husky": "9.1.7",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
