#!/bin/sh
echo "🔍 Running lint check before commit..."
bun run lint
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Lint failed. Please fix the errors above before committing."
  exit 1
fi
echo "✅ Lint passed."

echo "🧪 Running unit tests before commit..."
bun run test
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Tests failed. Please fix the failing tests above before committing."
  exit 1
fi
echo "✅ Tests passed."
