# =============================================================================
# Wealth Checker — STAGING Environment Variables
#
# For the lightweight, on-VPS STAGING profile only (docker-compose.staging.yml),
# running alongside the production stack on the same VPS with different
# ports/DB name — this is NOT the production .env. Copy to `.env.staging` on
# the VPS and fill in the values before running the staging stack. See
# docs/STAGING.md for full usage instructions.
# =============================================================================

# PostgreSQL (isolated staging DB/container — different name/port from production)
POSTGRES_DB=wealth_checker_staging
POSTGRES_USER=wealth
POSTGRES_PASSWORD=changeme_staging_password

# Better Auth
BETTER_AUTH_SECRET=changeme_32_chars_minimum_staging_secret
BETTER_AUTH_URL=http://localhost:4011

# API
DATABASE_URL=postgresql://wealth:changeme_staging_password@localhost:5434/wealth_checker_staging
PORT=4011
# Origin(s) allowed to call the staging API besides the defaults baked into
# apps/api/src/lib/auth.ts / index.ts — adjust to the VPS's public IP/hostname
# if you need to reach staging from outside localhost (comma-separated).
ADDITIONAL_TRUSTED_ORIGINS=http://localhost:4010

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:4011
