# =============================================================================
# Wealth Checker — Environment Variables
# Copy to .env and fill in the values
# =============================================================================

# PostgreSQL
POSTGRES_DB=wealth_checker
POSTGRES_USER=wealth
POSTGRES_PASSWORD=changeme_strong_password

# Redis
REDIS_PASSWORD=changeme_redis_password

# Better Auth
BETTER_AUTH_SECRET=changeme_32_chars_minimum_secret_key
BETTER_AUTH_URL=http://localhost:3011

# Email (Resend) — forgot/reset password
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Opsional — default onboarding@resend.dev (dev). Set ke alamat domain terverifikasi di production.
# RESEND_FROM_EMAIL=noreply@wealth.velrox.cloud

# API
DATABASE_URL=postgresql://wealth:changeme_strong_password@localhost:5433/wealth_checker
REDIS_URL=redis://:changeme_redis_password@localhost:6380
PORT=3011

# Notifikasi Push (Fase 4, Sprint 24)
# Generate dengan: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@wealth.velrox.cloud
# Opsional — hanya dibutuhkan kalau ada app mobile Android/iOS (belum ada saat ini)
FCM_SERVER_KEY=

# Household invite (Fase 4, Sprint 27) — dipakai membentuk link undangan
# yang dikembalikan API (belum ada provider email terkonfigurasi, lihat
# routes/households.ts). Harus sama dengan origin frontend (Next.js).
WEB_APP_URL=http://localhost:3010

# Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3011
# Sama dengan VAPID_PUBLIC_KEY di atas — publik, aman diekspos ke browser
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
