{
  "name": "@wealth/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "start": "bun run dist/index.js",
    "worker:dev": "bun run --hot src/worker.ts",
    "worker:build": "bun build src/worker.ts --outdir dist --target bun --minify",
    "worker:start": "bun run dist/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "backfill:wealth-snapshots": "bun run src/scripts/backfillWealthSnapshots.ts",
    "backfill:households": "bun run src/scripts/backfillHouseholds.ts",
    "loadtest": "bun run src/scripts/loadTest.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.5.0",
    "@wealth/db": "workspace:*",
    "better-auth": "^1.2.8",
    "bullmq": "^5.79.2",
    "drizzle-orm": "^0.44.0",
    "exceljs": "^4.4.0",
    "hono": "^4.12.27",
    "ioredis": "5.10.1",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.5",
    "resend": "^6.17.1",
    "web-push": "^3.6.7",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/web-push": "^3.6.4",
    "typescript": "^5"
  }
}